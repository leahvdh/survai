	pages = {e2305016120},
	file = {gilardi-et-al-chatgpt-outperforms-crowd-workers-for-text-annotation-tasks:/Users/leah/Zotero/storage/6IKIE9IU/gilardi-et-al-chatgpt-outperforms-crowd-workers-for-text-annotation-tasks.pdf:application/pdf;pnas.2305016120.sapp:/Users/leah/Zotero/storage/MDVKLXGL/pnas.2305016120.sapp.pdf:application/pdf},
