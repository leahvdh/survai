	pages = {e0000429},
	file = {Full Text PDF:/Users/leah/Zotero/storage/HPMMDNZS/Lee et al. - 2024 - Can large language models estimate public opinion about global warming An empirical assessment of a.pdf:application/pdf;Volltext:/Users/leah/Zotero/storage/68A5PH83/Lee et al. - 2023 - Can Large Language Models Capture Public Opinion a.pdf:application/pdf},
