	pages = {163--190},
	file = {Full Text PDF:/Users/leah/Zotero/storage/9MPEQ7GI/Lee et al. - 2023 - A Paradigm Shift from “Human Writing” to “Machine Generation” in Personality Test Development an Ap.pdf:application/pdf},
