Type: Article},
	keywords = {data: social media, data: Twitter, domain: public opinion, lang: English, stage: post-data collection, subtask: classification, subtask: sentiment analysis, task: data processing, topic: COVID-19, topic: health, WOS},
	pages = {512--520},
