	url = {https://www.semanticscholar.org/paper/45d0b1513475981e00a708fa0e0fd441756c18b6},
	doi = {10.1109/ICPRS62101.2024.10677804},
	abstract = {Today, platforms like YouTube provide a fertile environment for conspiracy theory communities, which can build their own fan bases and attract the attention of a wider audience. Moreover, they easily disseminate unverified narratives and misinformation, which has the potential to influence public opinion in a variety of online discussions.The aim of this study is to investigate emotional and topical patterns inherent to conspiracy theory narratives based on comments posted in three YouTube videos on the 2023 Hawaii wildfires. The first video from one of the popular conspiracy theory channels provides an explanation from the perspective of an unproven plot. The second, a mainstream media video, offers conventional coverage of the event, while the third one features an opinion of the event from the point of view of an independent video blogger. Videos were strategically chosen to allow comparisons between mainstream and conspiracy-related communication.The research applies methods based on LLMs (Large Language Models) to analyse sentimental and emotional responses in the comments as well as the representation of discussed topics. Thus, the analysis seeks to understand if conspiracy theory narratives influence the public perception of the Hawaiian Fires and assess the belief in these narratives along with their emotional palette. Early findings show that emotional and sentimental tones differ between the three comment sections. Comments under the conspiracy theory video demonstrate more disapproval, negative feelings, and less empathy than the general expression of mainstream and blogger comment sections. Furthermore, ideas raised in the comments of the conspiracy theory videos have substantial presence in the blogger’s video discussion and are less substantial in the mainstream video. The results demonstrate that the inclusion of emotions and topical patterns can be beneficial for the identification of conspiracy-related communication.},
	booktitle = {2024 14th {International} {Conference} on {Pattern} {Recognition} {Systems} ({ICPRS})},
	publisher = {IEEE},
	author = {Dubinko, Nikolai and Bayerl, P. and Abreu, Márjory Cristiany da Costa and Gibson, Helen},
